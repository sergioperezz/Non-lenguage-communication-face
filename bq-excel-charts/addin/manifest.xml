<?xml version="1.0" encoding="UTF-8"?>
<!--
  Manifiesto del Office Add-in. Registra el panel lateral (task pane) en Excel.
  El mismo manifiesto sirve de base para PowerPoint en la Fase 2 (basta añadir
  un <Host Name="Presentation"/>).

  Para probarlo en local: «sideload» este manifiesto en Excel.
  Sustituye el GUID por uno propio (genera uno nuevo) y las URLs por las de tu
  servidor de desarrollo (vite sirve en https://localhost:3000).
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="TaskPaneApp">

  <Id>00000000-0000-0000-0000-000000000000</Id>
  <Version>0.1.0</Version>
  <ProviderName>Tu Empresa</ProviderName>
  <DefaultLocale>es-ES</DefaultLocale>
  <DisplayName DefaultValue="BQ Charts" />
  <Description DefaultValue="Construye gráficos y tablas en Excel desde BigQuery." />

  <IconUrl DefaultValue="https://localhost:3000/assets/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://localhost:3000/assets/icon-80.png" />

  <Hosts>
    <Host Name="Workbook" />
  </Hosts>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://localhost:3000/index.html" />
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>
</OfficeApp>
