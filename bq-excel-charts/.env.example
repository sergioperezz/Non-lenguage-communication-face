# Copia a backend/.env y rellena. Sin GCP_PROJECT, el backend funciona en
# modo dry-run (compila SQL y devuelve datos simulados, sin tocar BigQuery).

# BQEC_GCP_PROJECT=mi-proyecto-gcp
# BQEC_GOOGLE_APPLICATION_CREDENTIALS=/ruta/service-account.json
# BQEC_SEMANTIC_MODEL_PATH=app/semantic/example_model.yaml
